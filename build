#!/bin/bash
# Creates a bootable SD card for an Raspberry Pi 5 with an encrypted root filesystem from an .img file in the current directory.
# The filesystem is decrypted using a connected USB key drive when the Raspberry Pi 5 boots.
# Tested images: 2025-12-04-raspios-trixie-arm64.img
#
# How to create a USB key drive:
# Use `lsblk -d` to list parent devices and locate your USB drive. If your USB drive is `sdb` then
# ```
# fdisk /dev/sdb # create a DOS MBR with a single primary partition (Id=83, Type=Linux)
# lsblk # show all devices. should list sdb1
# mkfs.ext4 -L KEY /dev/sdb1
# ```
# You can now copy the Encryption key created by the script to the USB drive.

if [ -z "$1" ]; then
  echo "Usage: $0 /dev/<NAME of SD card>" >&2
  echo ""
  echo "Locate your device NAME from the devices below:"
  lsblk -d
  exit 1
fi

SDCARD="$1"
SDCARD_P1="${SDCARD}1" # sdcard partition 1
SDCARD_P2="${SDCARD}2" # sdcard partition 2

ROOTFS="rootfs" # root filesystem volume name
ROOTFS_KEY="$ROOTFS.key" # encryption key

if [ ! -b "$SDCARD" ]; then
  echo "SDCARD $SDCARD not found" >&2
  exit 1
fi

IMAGE_PATH=$(ls *.img 2>/dev/null | head -n1)
if [ -z "$IMAGE_PATH" ]; then
  echo "No .img file found in the current directory" >&2
  exit 1
fi

echo "Creating a bootable sdcard with an encrypted root filesystem from $IMAGE_PATH ..."

mkdir -p image root

umount $SDCARD?*
umount /dev/loop0?*
losetup -d /dev/loop0
losetup -P /dev/loop0 "$IMAGE_PATH" 

IMAGE_MOUNT_PATH=$(realpath image)
if ! grep -qs " $IMAGE_MOUNT_PATH " /proc/mounts; then
  mount /dev/loop0p2 "$IMAGE_MOUNT_PATH"
fi

set -euo pipefail

sfdisk "$SDCARD" --force <<EOF
label: dos
label-id: 0xefab4ffe

$SDCARD_P1 : start=8192,    size=2097152,  type=b
$SDCARD_P2 : start=2105344,                type=83
EOF

echo "Running partprobe ..."
partprobe "$SDCARD"

dd if=/dev/loop0p1 of="$SDCARD_P1" bs=4M status=progress

if [ ! -f "$ROOTFS_KEY" ]; then
  # 64 bytes is ample for LUKS key material
  echo "Creating Encryption Key ..."
  head -c 64 /dev/urandom > "$ROOTFS_KEY"
  chmod 600 "$ROOTFS_KEY" # only the root account can read the key
fi
echo "Encryption Key at $ROOTFS_KEY. See script comments on how to create a USB key drive."

cryptsetup luksFormat "$SDCARD_P2" --key-file - < "$ROOTFS_KEY"

cryptsetup luksOpen --key-file "$ROOTFS_KEY" "$SDCARD_P2" $ROOTFS 

mkfs.ext4 -L $ROOTFS /dev/mapper/$ROOTFS

mount /dev/mapper/$ROOTFS root
(cd image && rsync -a --info=progress2 * ../root)
sync # be patient, this could take a while

BOOTFS_UUID="$(lsblk --noheadings --output=UUID $SDCARD_P1)"
ROOTFS_UUID="$(lsblk --nodeps --noheadings --output=UUID $SDCARD_P2)"

umount image
losetup -d /dev/loop0
rmdir image

cat > ./root/etc/fstab <<EOF
proc /proc proc defaults 0 0
UUID=$BOOTFS_UUID /boot/firmware vfat defaults 0 2
/dev/mapper/$ROOTFS / ext4 defaults,noatime 0 1
EOF

cat > ./root/etc/initramfs-tools/scripts/local-top/usb_key_unlock <<EOF
#!/bin/sh
echo "Running usb_key_unlock ..."
PREREQ="udev"
prereqs() { echo "\$PREREQ"; }
case "\$1" in prereqs) prereqs; exit 0 ;; esac

# Give USB subsystem time to enumerate
modprobe usb_storage 2>/dev/null
modprobe xhci_pci 2>/dev/null
sleep 5
udevadm settle --timeout=10

# Mount the USB decryption drive and unlock root
mkdir -p /key
if mount /dev/disk/by-label/KEY /key; then
  if [ -f /key/$ROOTFS_KEY ]; then
    cryptsetup luksOpen --key-file /key/$ROOTFS_KEY UUID=$ROOTFS_UUID $ROOTFS
    echo "Root filesystem unlocked via USB key."
  else
    echo "Key file /key/$ROOTFS_KEY not found on USB drive!"
  fi
  umount /key
else
  echo "Failed to mount USB drive!"
fi
echo "usb_key_unlock finished!"
EOF

chmod +x ./root/etc/initramfs-tools/scripts/local-top/usb_key_unlock

echo "$ROOTFS UUID=$ROOTFS_UUID none luks,initramfs" > ./root/etc/crypttab

# Rebuild initramfs inside chroot
mkdir -p ./root/boot/firmware
mount --bind /dev ./root/dev
mount --bind /proc ./root/proc
mount --bind /sys ./root/sys
mount "UUID=$BOOTFS_UUID" ./root/boot/firmware

# Replace root= and append cryptopts
sed -i -e "s|root=[^ ]*|root=/dev/mapper/$ROOTFS|" ./root/boot/firmware/cmdline.txt

# Append cryptopts if not already present
if ! grep -q "cryptopts=" ./root/boot/firmware/cmdline.txt; then
  sed -i "s|\$| cryptopts=target=$ROOTFS,source=UUID=${ROOTFS_UUID},luks|" ./root/boot/firmware/cmdline.txt
fi

chroot ./root /usr/bin/env -i LANG=C /bin/bash -c "sed -i 's/^# *en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/' /etc/locale.gen"
chroot ./root /usr/bin/env -i LANG=C /bin/bash -c "dpkg-reconfigure --frontend=noninteractive locales"

echo "Installing encryption packages ..."
chroot ./root /bin/bash -c "apt-get update && apt-get install -y initramfs-tools cryptsetup-initramfs"

cat >> ./root/etc/cryptsetup-initramfs/conf-hook <<EOF
CRYPTSETUP=y
EOF

# USB + filesystem modules needed to mount the key drive in initramfs
cat > ./root/etc/initramfs-tools/modules <<EOF
# List of modules that you want to include in your initramfs.
# They will be loaded at boot time in the order below.
#
# Syntax:  module_name [args ...]
#
# You must run update-initramfs(8) to effect this change.
#
# Examples:
#
# raid1
# sd_mod

xhci_hcd
xhci_pci
xhci_plat_hcd
usbcore
usb_common
usb_storage
uas
sd_mod
scsi_mod
sg
vfat
fat
msdos
nls_cp437
nls_ascii
nls_utf8
ext4
EOF

chroot ./root /bin/bash -c "update-initramfs -u -k all"

echo "SD card partitions ready. Press any key to complete the installation ..."
read user_input

umount ./root/boot/firmware
umount ./root/sys
umount ./root/proc
umount ./root/dev

umount root
cryptsetup luksClose $ROOTFS 

rmdir root

eject "$SDCARD"
